<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services – MindConnect</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --green: #10a37f;
            --green-dark: #0c8a6b;
            --green-light: #e8f7f3;
            --ink: #0f1923;
            --ink2: #374151;
            --muted: #6b7280;
            --border: #e5e7eb;
            --surface: #f9fafb;
            --white: #ffffff;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--ink); line-height: 1.6; -webkit-font-smoothing: antialiased; }
 
        header {
            position: fixed; top: 0; width: 100%;
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            z-index: 999;
        }
        nav {
            max-width: 1200px; margin: 0 auto; padding: 0 24px;
            display: flex; justify-content: space-between; align-items: center; height: 68px;
        }
        .logo { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: var(--green); text-decoration: none; }
        .nav-links { display: flex; list-style: none; gap: 8px; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--ink2); font-weight: 500; font-size: 15px; padding: 8px 14px; border-radius: 8px; transition: all 0.2s; }
        .nav-links a:hover { background: var(--green-light); color: var(--green); }
        .nav-links a.active { color: var(--green); font-weight: 600; background: var(--green-light); }
        .nav-cta { background: var(--green) !important; color: white !important; padding: 9px 18px !important; border-radius: 8px !important; }
        .nav-cta:hover { background: var(--green-dark) !important; color: white !important; }
 
        /* PAGE HERO */
        .page-hero {
            padding-top: 68px;
            background: linear-gradient(135deg, #f0fdf8 0%, #fafffe 60%, #f0f9ff 100%);
            padding-bottom: 0;
        }
        .page-hero-inner {
            max-width: 1200px; margin: 0 auto; padding: 80px 24px 0;
        }
        .breadcrumb { font-size: 13px; color: var(--muted); margin-bottom: 20px; }
        .breadcrumb a { color: var(--green); text-decoration: none; }
        .breadcrumb a:hover { text-decoration: underline; }
        .page-hero h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(40px, 6vw, 64px);
            font-weight: 800;
            line-height: 1.1;
            letter-spacing: -0.03em;
            margin-bottom: 20px;
            max-width: 700px;
        }
        .page-hero p {
            font-size: 18px; color: var(--muted); line-height: 1.65; max-width: 560px; margin-bottom: 48px;
        }
        .hero-tabs {
            display: flex; gap: 0; border-bottom: 2px solid var(--border);
        }
        .hero-tab {
            padding: 14px 24px; font-size: 15px; font-weight: 600; color: var(--muted);
            cursor: pointer; border-bottom: 3px solid transparent; margin-bottom: -2px;
            transition: all 0.2s; text-decoration: none; display: block;
        }
        .hero-tab.active, .hero-tab:hover { color: var(--green); border-bottom-color: var(--green); }
 
        /* SERVICES SECTION */
        .services-section { padding: 80px 0; }
        .services-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
 
        .service-block {
            display: grid; grid-template-columns: 1fr 1fr; gap: 60px;
            align-items: center; margin-bottom: 100px; padding-bottom: 100px;
            border-bottom: 1px solid var(--border);
        }
        .service-block:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        .service-block.flip { direction: rtl; }
        .service-block.flip > * { direction: ltr; }
 
        .service-section-tag {
            display: inline-block; padding: 4px 12px; background: var(--green); color: white;
            font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
            border-radius: 4px; margin-bottom: 16px;
        }
        .service-block h2 {
            font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 700;
            line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 16px;
        }
        .service-block p { font-size: 16px; color: var(--muted); line-height: 1.7; margin-bottom: 14px; }
 
        .feature-list { list-style: none; margin: 24px 0; }
        .feature-list li {
            display: flex; align-items: flex-start; gap: 12px;
            font-size: 15px; margin-bottom: 12px; color: var(--ink2);
        }
        .feature-list li::before { content: '✓'; color: var(--green); font-weight: 700; flex-shrink: 0; margin-top: 2px; }
 
        .service-visual {
            background: white; border: 1px solid var(--border); border-radius: 20px;
            padding: 36px; box-shadow: 0 8px 40px rgba(0,0,0,0.06);
        }
 
        .visual-header { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }
        .visual-icon { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; }
        .icon-green { background: var(--green-light); }
        .icon-blue { background: #eff6ff; }
        .icon-purple { background: #f5f3ff; }
        .icon-amber { background: #fffbeb; }
        .visual-header h3 { font-weight: 700; font-size: 18px; }
        .visual-header p { font-size: 13px; color: var(--muted); }
 
        .mini-card {
            background: var(--surface); border-radius: 12px; padding: 16px; margin-bottom: 12px;
        }
        .mini-card:last-child { margin-bottom: 0; }
        .mini-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
        .mini-card-label { font-size: 14px; font-weight: 600; }
        .mini-card-value { font-size: 13px; color: var(--muted); }
        .progress-bar { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
        .progress-fill { height: 100%; background: var(--green); border-radius: 3px; }
 
        /* Medication visual */
        .med-schedule { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .med-pill {
            background: var(--surface); border-radius: 10px; padding: 14px;
            display: flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 500;
        }
        .dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
        .dot-green { background: var(--green); }
        .dot-blue { background: #6366f1; }
        .dot-amber { background: #f59e0b; }
        .dot-red { background: #ef4444; }
 
        /* Education visual */
        .edu-modules { display: flex; flex-direction: column; gap: 10px; }
        .edu-module {
            background: var(--surface); border-radius: 10px; padding: 14px 16px;
            display: flex; align-items: center; gap: 14px; font-size: 14px;
        }
        .module-num { width: 28px; height: 28px; background: var(--green); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
        .module-info h5 { font-weight: 600; font-size: 14px; }
        .module-info p { font-size: 12px; color: var(--muted); }
        .module-status { margin-left: auto; font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 20px; }
        .status-done { background: var(--green-light); color: var(--green); }
        .status-active { background: #eff6ff; color: #3b82f6; }
        .status-next { background: var(--surface); border: 1px solid var(--border); color: var(--muted); }
 
        /* Support visual */
        .chat-window { display: flex; flex-direction: column; gap: 12px; }
        .chat-msg { max-width: 80%; }
        .chat-msg.out { align-self: flex-end; }
        .chat-bubble {
            padding: 12px 16px; border-radius: 16px; font-size: 14px; line-height: 1.45;
        }
        .chat-bubble.in { background: var(--surface); color: var(--ink); border-bottom-left-radius: 4px; }
        .chat-bubble.out { background: var(--green); color: white; border-bottom-right-radius: 4px; }
        .chat-meta { font-size: 11px; color: var(--muted); margin-top: 4px; padding: 0 4px; }
        .chat-typing { display: flex; align-items: center; gap: 4px; padding: 12px 16px; background: var(--surface); border-radius: 16px; border-bottom-left-radius: 4px; width: fit-content; }
        .typing-dot { width: 6px; height: 6px; background: var(--muted); border-radius: 50%; animation: typingBounce 1.2s infinite; }
        .typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .typing-dot:nth-child(3) { animation-delay: 0.4s; }
        @keyframes typingBounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
 
        /* BOTTOM CTA */
        .bottom-cta {
            background: var(--ink); padding: 80px 0; text-align: center;
        }
        .bottom-cta-inner { max-width: 560px; margin: 0 auto; padding: 0 24px; }
        .bottom-cta h2 { font-family: 'Playfair Display', serif; font-size: 40px; font-weight: 700; color: white; margin-bottom: 16px; letter-spacing: -0.02em; }
        .bottom-cta p { font-size: 17px; color: rgba(255,255,255,0.6); margin-bottom: 32px; line-height: 1.6; }
        .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: var(--green); color: white; border: none; border-radius: 10px; font-size: 15px; font-weight: 600; font-family: inherit; cursor: pointer; text-decoration: none; transition: all 0.2s; }
        .btn-primary:hover { background: var(--green-dark); transform: translateY(-2px); box-shadow: 0 8px 25px rgba(16,163,127,0.3); }
 
        footer { background: #090e14; color: rgba(255,255,255,0.4); padding: 36px 0; }
        .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
        .footer-logo { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: white; }
        .footer-links { display: flex; gap: 20px; }
        .footer-links a { text-decoration: none; color: rgba(255,255,255,0.4); font-size: 14px; transition: color 0.2s; }
        .footer-links a:hover { color: white; }
 
        .reveal { opacity: 0; transform: translateY(24px); transition: all 0.7s ease; }
        .reveal.in-view { opacity: 1; transform: translateY(0); }
 
        @media (max-width: 900px) {
            .service-block { grid-template-columns: 1fr; gap: 40px; }
            .service-block.flip { direction: ltr; }
            .nav-links { display: none; }
        }
    </style>
</head>
<body>
 
<header>
    <nav>
        <a href="index.html" class="logo">MindConnect</a>
        <ul class="nav-links">
            <li><a href="services.html" class="active">Services</a></li>
            <li><a href="network.html">Network</a></li>
            <li><a href="mission.html">Mission</a></li>
            <li><a href="about.html">About</a></li>
            <li><a href="contact.html" class="nav-cta">Get Started</a></li>
        </ul>
    </nav>
</header>
 
<div class="page-hero">
    <div class="page-hero-inner">
        <div class="breadcrumb"><a href="index.html">Home</a> / Services</div>
        <h1>Comprehensive Mental Health Services</h1>
        <p>Everything you need to manage your mental health with confidence — delivered through our expert-designed support system.</p>
        <div class="hero-tabs">
            <a href="#nutrition" class="hero-tab active">Nutrition Planning</a>
            <a href="#medication" class="hero-tab">Medication Mgmt</a>
            <a href="#education" class="hero-tab">Health Education</a>
            <a href="#support" class="hero-tab">24/7 Support</a>
        </div>
    </div>
</div>
 
<section class="services-section">
    <div class="services-inner">
 
        <!-- Nutrition -->
        <div class="service-block reveal" id="nutrition">
            <div class="service-text">
                <div class="service-section-tag">01 — Nutrition Planning</div>
                <h2>Eat Well, Feel Well</h2>
                <p>Personalized meal plans and nutritional guidance crafted by certified nutritionists to optimize your diet and support your mental health journey.</p>
                <p>Research shows that nutrition plays a critical role in mental health outcomes. Our team helps bridge the gap between what you eat and how you feel.</p>
                <ul class="feature-list">
                    <li>One-on-one consultations with certified nutritionists</li>
                    <li>Personalized meal plans tailored to your health goals</li>
                    <li>Grocery guidance and budget-friendly meal options</li>
                    <li>Nutritional education workshops (group & individual)</li>
                    <li>Cultural food preferences honored and incorporated</li>
                </ul>
                <a href="contact.html" class="btn-primary">Book a Consultation →</a>
            </div>
            <div class="service-visual">
                <div class="visual-header">
                    <div class="visual-icon icon-green">🥗</div>
                    <div>
                        <h3>Your Nutrition Plan</h3>
                        <p>Weekly progress — Week 4 of 12</p>
                    </div>
                </div>
                <div class="mini-card">
                    <div class="mini-card-top"><span class="mini-card-label">Daily Nutrient Goals</span><span class="mini-card-value">On Track ✓</span></div>
                    <div class="progress-bar"><div class="progress-fill" style="width:82%"></div></div>
                </div>
                <div class="mini-card">
                    <div class="mini-card-top"><span class="mini-card-label">Hydration</span><span class="mini-card-value">6 / 8 glasses</span></div>
                    <div class="progress-bar"><div class="progress-fill" style="width:75%"></div></div>
                </div>
                <div class="mini-card">
                    <div class="mini-card-top"><span class="mini-card-label">Meal Plan Adherence</span><span class="mini-card-value">92% this week</span></div>
                    <div class="progress-bar"><div class="progress-fill" style="width:92%"></div></div>
                </div>
                <div class="mini-card" style="background: var(--green-light); border: 1px solid #b8ead8;">
                    <div style="font-size:13px; color: var(--green); font-weight:600;">🌟 Next Milestone</div>
                    <div style="font-size:13px; color: var(--muted); margin-top:4px;">Complete Week 4 check-in with your nutritionist on Friday</div>
                </div>
            </div>
        </div>
 
        <!-- Medication -->
        <div class="service-block flip reveal" id="medication">
            <div class="service-text">
                <div class="service-section-tag">02 — Medication Management</div>
                <h2>Safe, Smart Medication Support</h2>
                <p>Secure, climate-controlled medication storage with smart dispensing technology designed specifically for vulnerable populations managing complex medication regimens.</p>
                <p>We partner with local pharmacies and psychiatrists to ensure you never miss a dose and always have access to the medications you need.</p>
                <ul class="feature-list">
                    <li>Smart medication reminders and adherence tracking</li>
                    <li>Secure storage solutions for multiple medications</li>
                    <li>Pharmacy partnership for refill coordination</li>
                    <li>Medication assistance programs for uninsured patients</li>
                    <li>Drug interaction consultation with specialists</li>
                </ul>
                <a href="contact.html" class="btn-primary">Learn More →</a>
            </div>
            <div class="service-visual">
                <div class="visual-header">
                    <div class="visual-icon icon-blue">💊</div>
                    <div>
                        <h3>Medication Schedule</h3>
                        <p>Today — Monday</p>
                    </div>
                </div>
                <div class="med-schedule">
                    <div class="med-pill"><div class="dot dot-green"></div><div><div style="font-size:13px;font-weight:600;">8:00 AM</div><div style="font-size:12px;color:var(--muted);">Taken ✓</div></div></div>
                    <div class="med-pill"><div class="dot dot-blue"></div><div><div style="font-size:13px;font-weight:600;">12:00 PM</div><div style="font-size:12px;color:var(--muted);">Taken ✓</div></div></div>
                    <div class="med-pill"><div class="dot dot-amber"></div><div><div style="font-size:13px;font-weight:600;">6:00 PM</div><div style="font-size:12px;color:#f59e0b;font-weight:600;">Due Soon</div></div></div>
                    <div class="med-pill"><div class="dot dot-red"></div><div><div style="font-size:13px;font-weight:600;">9:00 PM</div><div style="font-size:12px;color:var(--muted);">Upcoming</div></div></div>
                </div>
                <div class="mini-card" style="margin-top:12px;">
                    <div class="mini-card-top"><span class="mini-card-label">Monthly Adherence</span><span class="mini-card-value">96%</span></div>
                    <div class="progress-bar"><div class="progress-fill" style="width:96%"></div></div>
                </div>
                <div class="mini-card">
                    <div style="font-size:13px;color:var(--muted);">🔔 Refill reminder: <strong>Prescription A</strong> refill in 5 days — auto-coordinated with your pharmacy</div>
                </div>
            </div>
        </div>
 
        <!-- Education -->
        <div class="service-block reveal" id="education">
            <div class="service-text">
                <div class="service-section-tag">03 — Health Education</div>
                <h2>Knowledge is the Foundation of Recovery</h2>
                <p>Comprehensive mental health education programs covering lifestyle management, prevention strategies, and health optimization — in English and Spanish.</p>
                <p>Our structured curriculum was developed with board-certified mental health professionals to ensure every lesson is evidence-based and immediately actionable.</p>
                <ul class="feature-list">
                    <li>Self-paced digital modules available anytime</li>
                    <li>Live group workshops with licensed educators</li>
                    <li>Mental health literacy and stigma reduction</li>
                    <li>Coping strategies and stress management techniques</li>
                    <li>Family education and caregiver support resources</li>
                </ul>
                <a href="contact.html" class="btn-primary">Explore Curriculum →</a>
            </div>
            <div class="service-visual">
                <div class="visual-header">
                    <div class="visual-icon icon-purple">📚</div>
                    <div>
                        <h3>Your Learning Path</h3>
                        <p>Mental Health Foundations</p>
                    </div>
                </div>
                <div class="edu-modules">
                    <div class="edu-module">
                        <div class="module-num">1</div>
                        <div class="module-info"><h5>Understanding Mental Health</h5><p>30 min · Completed</p></div>
                        <div class="module-status status-done">Done</div>
                    </div>
                    <div class="edu-module">
                        <div class="module-num">2</div>
                        <div class="module-info"><h5>Stress & Coping Strategies</h5><p>45 min · In progress</p></div>
                        <div class="module-status status-active">Active</div>
                    </div>
                    <div class="edu-module">
                        <div class="module-num">3</div>
                        <div class="module-info"><h5>Building Support Networks</h5><p>40 min · Upcoming</p></div>
                        <div class="module-status status-next">Next</div>
                    </div>
                    <div class="edu-module">
                        <div class="module-num">4</div>
                        <div class="module-info"><h5>Nutrition & Mental Wellness</h5><p>35 min · Upcoming</p></div>
                        <div class="module-status status-next">Next</div>
                    </div>
                </div>
            </div>
        </div>
 
        <!-- 24/7 Support -->
        <div class="service-block flip reveal" id="support">
            <div class="service-text">
                <div class="service-section-tag">04 — 24/7 Support</div>
                <h2>Always Here When You Need Us</h2>
                <p>Round-the-clock access to certified mental health professionals and peer support specialists when you need them most. No waiting rooms, no appointments required for urgent support.</p>
                <p>Our peer support specialists — many of whom have lived experience with mental health challenges — provide authentic, empathetic guidance any time, day or night.</p>
                <ul class="feature-list">
                    <li>Immediate chat and phone access, 24 hours a day</li>
                    <li>Certified peer support specialists on every shift</li>
                    <li>Crisis intervention and safety planning support</li>
                    <li>Warm referrals to local emergency services if needed</li>
                    <li>Follow-up care coordination after crisis episodes</li>
                </ul>
                <a href="contact.html" class="btn-primary">Connect Now →</a>
            </div>
            <div class="service-visual">
                <div class="visual-header">
                    <div class="visual-icon icon-amber">🛟</div>
                    <div>
                        <h3>Support Chat</h3>
                        <p>Specialist available now · avg 2 min response</p>
                    </div>
                </div>
                <div class="chat-window">
                    <div class="chat-msg">
                        <div class="chat-bubble in">Hi! I'm Maria, your peer support specialist. How are you feeling today?</div>
                        <div class="chat-meta">Maria · 2:14 PM</div>
                    </div>
                    <div class="chat-msg out">
                        <div class="chat-bubble out">I've been feeling really anxious today and I'm not sure what to do.</div>
                        <div class="chat-meta" style="text-align:right;">You · 2:16 PM</div>
                    </div>
                    <div class="chat-msg">
                        <div class="chat-bubble in">I hear you — that's really hard. Let's work through this together. Can you tell me more about what's been happening?</div>
                        <div class="chat-meta">Maria · 2:16 PM</div>
                    </div>
                    <div class="chat-typing">
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                    </div>
                </div>
            </div>
        </div>
 
    </div>
</section>
 
<div class="bottom-cta">
    <div class="bottom-cta-inner">
        <h2>Ready to Get Started?</h2>
        <p>All services are available in English and Spanish, and we work with all income levels.</p>
        <a href="contact.html" class="btn-primary" style="font-size:16px; padding:16px 36px;">Reach Out Today →</a>
    </div>
</div>
 
<footer>
    <div class="footer-inner">
        <div class="footer-logo">MindConnect</div>
        <div class="footer-links">
            <a href="services.html">Services</a>
            <a href="network.html">Network</a>
            <a href="mission.html">Mission</a>
            <a href="about.html">About</a>
            <a href="contact.html">Contact</a>
        </div>
        <div style="font-size:13px;">© 2025 MindConnect.</div>
    </div>
</footer>
 
<script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
