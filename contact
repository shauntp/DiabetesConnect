<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Get Started – MindConnect</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --green: #10a37f;
            --green-dark: #0c8a6b;
            --green-light: #e8f7f3;
            --ink: #0f1923;
            --ink2: #374151;
            --muted: #6b7280;
            --border: #e5e7eb;
            --surface: #f9fafb;
            --white: #ffffff;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--ink); line-height: 1.6; -webkit-font-smoothing: antialiased; }

        header { position: fixed; top: 0; width: 100%; background: rgba(255,255,255,0.97); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); z-index: 999; }
        nav { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; justify-content: space-between; align-items: center; height: 68px; }
        .logo { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: var(--green); text-decoration: none; }
        .nav-links { display: flex; list-style: none; gap: 8px; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--ink2); font-weight: 500; font-size: 15px; padding: 8px 14px; border-radius: 8px; transition: all 0.2s; }
        .nav-links a:hover { background: var(--green-light); color: var(--green); }
        .nav-links a.active { color: var(--green); font-weight: 600; background: var(--green-light); }
        .nav-cta { background: var(--green) !important; color: white !important; padding: 9px 18px !important; border-radius: 8px !important; }
        .nav-cta:hover { background: var(--green-dark) !important; color: white !important; }

        /* CONTACT LAYOUT */
        .contact-page {
            padding-top: 68px;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        /* LEFT PANEL */
        .contact-left {
            background: var(--ink);
            padding: 80px 60px;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .contact-left::before {
            content: '';
            position: absolute;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(16,163,127,0.2) 0%, transparent 70%);
            bottom: -100px; left: -100px;
            border-radius: 50%;
        }
        .breadcrumb { font-size: 13px; color: rgba(255,255,255,0.4); margin-bottom: 40px; }
        .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
        .contact-left h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(36px, 4vw, 52px); font-weight: 800;
            line-height: 1.1; letter-spacing: -0.025em;
            color: white; margin-bottom: 20px;
            position: relative; z-index: 1;
        }
        .contact-left > p {
            font-size: 17px; color: rgba(255,255,255,0.65);
            line-height: 1.7; margin-bottom: 48px;
            position: relative; z-index: 1; max-width: 400px;
        }

        .contact-info { position: relative; z-index: 1; }
        .contact-info-item {
            display: flex; align-items: flex-start; gap: 16px; margin-bottom: 28px;
        }
        .contact-info-item:last-child { margin-bottom: 0; }
        .info-icon {
            width: 42px; height: 42px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; flex-shrink: 0;
        }
        .info-label { font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
        .info-value { font-size: 15px; color: white; font-weight: 500; }

        .reassurance-block {
            margin-top: 48px; padding: 24px; position: relative; z-index: 1;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px;
        }
        .reassurance-block h4 { font-size: 14px; font-weight: 700; color: white; margin-bottom: 12px; }
        .reassurance-item {
            display: flex; align-items: center; gap: 10px; font-size: 14px;
            color: rgba(255,255,255,0.6); margin-bottom: 8px;
        }
        .reassurance-item:last-child { margin-bottom: 0; }
        .reassurance-item::before { content: '✓'; color: var(--green); font-weight: 700; flex-shrink: 0; }

        /* RIGHT PANEL - FORM */
        .contact-right {
            padding: 80px 60px;
            overflow-y: auto;
        }
        .form-title {
            font-family: 'Playfair Display', serif;
            font-size: 28px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.015em;
        }
        .form-subtitle { font-size: 15px; color: var(--muted); margin-bottom: 40px; }

        /* STEP INDICATOR */
        .step-indicator {
            display: flex; align-items: center; gap: 0; margin-bottom: 40px;
        }
        .step-dot {
            width: 32px; height: 32px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 700; flex-shrink: 0;
            transition: all 0.3s;
        }
        .step-dot.done { background: var(--green); color: white; }
        .step-dot.active { background: var(--ink); color: white; }
        .step-dot.pending { background: var(--surface); border: 1px solid var(--border); color: var(--muted); }
        .step-line { flex: 1; height: 2px; background: var(--border); margin: 0 8px; transition: background 0.3s; }
        .step-line.done { background: var(--green); }

        /* FORM STEPS */
        .form-step { display: none; }
        .form-step.active { display: block; }

        .form-group { margin-bottom: 22px; }
        .form-group label {
            display: block; margin-bottom: 8px;
            font-weight: 600; font-size: 14px; color: var(--ink);
        }
        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%; padding: 13px 16px;
            border: 1.5px solid var(--border); border-radius: 10px;
            font-size: 15px; font-family: inherit;
            background: var(--white); color: var(--ink);
            transition: all 0.2s; outline: none;
        }
        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 3px rgba(16,163,127,0.1);
        }
        .form-group textarea { resize: vertical; min-height: 120px; }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

        .checkbox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 8px; }
        .checkbox-option {
            display: flex; align-items: center; gap: 10px;
            padding: 12px 16px; border: 1.5px solid var(--border); border-radius: 10px;
            cursor: pointer; transition: all 0.2s; font-size: 14px; font-weight: 500;
        }
        .checkbox-option:hover { border-color: var(--green); background: var(--green-light); }
        .checkbox-option input { display: none; }
        .checkbox-option.selected { border-color: var(--green); background: var(--green-light); color: var(--green); }
        .checkbox-check { width: 18px; height: 18px; border: 1.5px solid var(--border); border-radius: 5px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; }
        .checkbox-option.selected .checkbox-check { background: var(--green); border-color: var(--green); color: white; }

        .lang-toggle { display: flex; gap: 10px; margin-top: 8px; }
        .lang-btn {
            flex: 1; padding: 12px; border: 1.5px solid var(--border); border-radius: 10px;
            text-align: center; font-size: 14px; font-weight: 600; cursor: pointer;
            transition: all 0.2s; background: var(--white); color: var(--ink2);
        }
        .lang-btn.selected { border-color: var(--green); background: var(--green-light); color: var(--green); }

        .btn-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 32px; gap: 12px; }
        .btn-primary {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; background: var(--green); color: white;
            border: none; border-radius: 10px; font-size: 15px; font-weight: 600;
            font-family: inherit; cursor: pointer; text-decoration: none; transition: all 0.2s;
        }
        .btn-primary:hover { background: var(--green-dark); transform: translateY(-1px); }
        .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
        .btn-back {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 14px 20px; background: transparent; color: var(--muted);
            border: 1.5px solid var(--border); border-radius: 10px; font-size: 15px; font-weight: 600;
            font-family: inherit; cursor: pointer; transition: all 0.2s;
        }
        .btn-back:hover { border-color: var(--ink); color: var(--ink); }

        /* SUCCESS */
        .success-screen {
            display: none; text-align: center; padding: 40px 0;
        }
        .success-screen.show { display: block; }
        .success-icon {
            width: 80px; height: 80px; background: var(--green-light); border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 36px; margin: 0 auto 24px;
        }
        .success-screen h2 { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; margin-bottom: 12px; }
        .success-screen p { font-size: 16px; color: var(--muted); line-height: 1.65; margin-bottom: 8px; }
        .success-email { font-weight: 600; color: var(--green); }
        .next-steps { background: var(--surface); border-radius: 14px; padding: 28px; margin-top: 32px; text-align: left; }
        .next-steps h4 { font-size: 15px; font-weight: 700; margin-bottom: 16px; }
        .next-step-item { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 14px; }
        .next-step-item:last-child { margin-bottom: 0; }
        .step-num { width: 24px; height: 24px; background: var(--green); color: white; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
        .next-step-item p { font-size: 14px; color: var(--ink2); line-height: 1.5; }

        .progress-bar-wrap { height: 4px; background: var(--border); border-radius: 2px; margin-bottom: 40px; }
        .progress-bar-fill { height: 100%; background: var(--green); border-radius: 2px; transition: width 0.4s ease; }

        /* MESSAGES */
        .field-error { font-size: 13px; color: #dc2626; margin-top: 6px; display: none; }
        .field-error.show { display: block; }

        footer { background: #090e14; color: rgba(255,255,255,0.4); padding: 36px 0; }
        .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
        .footer-logo { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: white; }
        .footer-links { display: flex; gap: 20px; }
        .footer-links a { text-decoration: none; color: rgba(255,255,255,0.4); font-size: 14px; transition: color 0.2s; }
        .footer-links a:hover { color: white; }

        @media (max-width: 900px) {
            .contact-page { grid-template-columns: 1fr; }
            .contact-left { padding: 60px 24px; }
            .contact-right { padding: 60px 24px; }
            .form-row { grid-template-columns: 1fr; }
            .checkbox-grid { grid-template-columns: 1fr; }
            .nav-links { display: none; }
        }
    </style>
</head>
<body>

<header>
    <nav>
        <a href="index.html" class="logo">MindConnect</a>
        <ul class="nav-links">
            <li><a href="services.html">Services</a></li>
            <li><a href="network.html">Network</a></li>
            <li><a href="mission.html">Mission</a></li>
            <li><a href="about.html">About</a></li>
            <li><a href="contact.html" class="nav-cta active">Get Started</a></li>
        </ul>
    </nav>
</header>

<div class="contact-page">
    <!-- LEFT -->
    <div class="contact-left">
        <div>
            <div class="breadcrumb"><a href="index.html">Home</a> / Get Started</div>
            <h1>Begin Your Journey to Better Mental Health</h1>
            <p>Fill out this short form and our team will reach out within 48 hours to connect you with the right support. All information is kept strictly confidential.</p>
        </div>
        <div class="contact-info">
            <div class="contact-info-item">
                <div class="info-icon">📧</div>
                <div>
                    <div class="info-label">Email Us</div>
                    <div class="info-value">info@mindconnect.live</div>
                </div>
            </div>
            <div class="contact-info-item">
                <div class="info-icon">🕐</div>
                <div>
                    <div class="info-label">Response Time</div>
                    <div class="info-value">Within 48 hours</div>
                </div>
            </div>
            <div class="contact-info-item">
                <div class="info-icon">🌎</div>
                <div>
                    <div class="info-label">Languages</div>
                    <div class="info-value">English & Spanish</div>
                </div>
            </div>
            <div class="contact-info-item">
                <div class="info-icon">🛟</div>
                <div>
                    <div class="info-label">Crisis Support</div>
                    <div class="info-value">Available 24/7</div>
                </div>
            </div>

            <div class="reassurance-block">
                <h4>You're in safe hands</h4>
                <div class="reassurance-item">All information is strictly confidential</div>
                <div class="reassurance-item">HIPAA compliant and secure</div>
                <div class="reassurance-item">No insurance required</div>
                <div class="reassurance-item">All income levels welcome</div>
                <div class="reassurance-item">No judgment, ever</div>
            </div>
        </div>
    </div>

    <!-- RIGHT - FORM -->
    <div class="contact-right">
        <div class="form-title">Let's Get You Connected</div>
        <div class="form-subtitle">This takes about 2 minutes. We'll do the rest.</div>

        <div class="progress-bar-wrap">
            <div class="progress-bar-fill" id="progressFill" style="width: 33%"></div>
        </div>

        <div class="step-indicator">
            <div class="step-dot active" id="dot1">1</div>
            <div class="step-line" id="line1"></div>
            <div class="step-dot pending" id="dot2">2</div>
            <div class="step-line" id="line2"></div>
            <div class="step-dot pending" id="dot3">3</div>
        </div>

        <!-- STEP 1: About You -->
        <div class="form-step active" id="step1">
            <div style="font-weight:700; font-size:18px; margin-bottom:6px;">Step 1 — About You</div>
            <div style="font-size:14px; color:var(--muted); margin-bottom:28px;">Tell us a bit about yourself so we can connect you with the right team member.</div>

            <div class="form-row">
                <div class="form-group">
                    <label for="firstName">First Name *</label>
                    <input type="text" id="firstName" placeholder="First name" autocomplete="given-name">
                    <div class="field-error" id="err-firstName">Please enter your first name.</div>
                </div>
                <div class="form-group">
                    <label for="lastName">Last Name *</label>
                    <input type="text" id="lastName" placeholder="Last name" autocomplete="family-name">
                    <div class="field-error" id="err-lastName">Please enter your last name.</div>
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email Address *</label>
                <input type="email" id="email" placeholder="your.email@example.com" autocomplete="email">
                <div class="field-error" id="err-email">Please enter a valid email address.</div>
            </div>

            <div class="form-group">
                <label for="phone">Phone Number (Optional)</label>
                <input type="tel" id="phone" placeholder="(555) 123-4567" autocomplete="tel">
            </div>

            <div class="form-group">
                <label>Preferred Language</label>
                <div class="lang-toggle">
                    <div class="lang-btn selected" data-lang="english" onclick="selectLang(this)">🇺🇸 English</div>
                    <div class="lang-btn" data-lang="spanish" onclick="selectLang(this)">🇲🇽 Español</div>
                    <div class="lang-btn" data-lang="both" onclick="selectLang(this)">Both</div>
                </div>
            </div>

            <div class="btn-nav">
                <div></div>
                <button class="btn-primary" onclick="goToStep(2)">Continue →</button>
            </div>
        </div>

        <!-- STEP 2: What You Need -->
        <div class="form-step" id="step2">
            <div style="font-weight:700; font-size:18px; margin-bottom:6px;">Step 2 — What You Need</div>
            <div style="font-size:14px; color:var(--muted); margin-bottom:28px;">Help us understand how we can best support you.</div>

            <div class="form-group">
                <label>What services are you interested in? (Select all that apply)</label>
                <div class="checkbox-grid" id="serviceGrid">
                    <div class="checkbox-option" onclick="toggleCheck(this)">
                        <div class="checkbox-check"></div> 🥗 Nutrition Planning
                    </div>
                    <div class="checkbox-option" onclick="toggleCheck(this)">
                        <div class="checkbox-check"></div> 💊 Medication Management
                    </div>
                    <div class="checkbox-option" onclick="toggleCheck(this)">
                        <div class="checkbox-check"></div> 📚 Health Education
                    </div>
                    <div class="checkbox-option" onclick="toggleCheck(this)">
                        <div class="checkbox-check"></div> 🛟 24/7 Support
                    </div>
                    <div class="checkbox-option" onclick="toggleCheck(this)">
                        <div class="checkbox-check"></div> 🏥 Provider Referral
                    </div>
                    <div class="checkbox-option" onclick="toggleCheck(this)">
                        <div class="checkbox-check"></div> ❓ General Inquiry
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="situation">How would you describe your current situation? (Optional)</label>
                <select id="situation">
                    <option value="">Select an option...</option>
                    <option>I'm just getting started and exploring options</option>
                    <option>I have a diagnosis and need support resources</option>
                    <option>I'm struggling right now and need help urgently</option>
                    <option>I'm a caregiver looking for resources for someone else</option>
                    <option>I want to learn more before taking any steps</option>
                </select>
            </div>

            <div class="btn-nav">
                <button class="btn-back" onclick="goToStep(1)">← Back</button>
                <button class="btn-primary" onclick="goToStep(3)">Continue →</button>
            </div>
        </div>

        <!-- STEP 3: Message -->
        <div class="form-step" id="step3">
            <div style="font-weight:700; font-size:18px; margin-bottom:6px;">Step 3 — Your Message</div>
            <div style="font-size:14px; color:var(--muted); margin-bottom:28px;">Tell us anything else we should know — the more context, the better we can help.</div>

            <div class="form-group">
                <label for="message">How can we help you? *</label>
                <textarea id="message" placeholder="Tell us about your goals, your situation, or any questions you have. There's no wrong answer — this is a safe space." rows="6"></textarea>
                <div class="field-error" id="err-message">Please share a bit about how we can help.</div>
            </div>

            <div class="form-group">
                <label for="hearAbout">How did you hear about MindConnect? (Optional)</label>
                <select id="hearAbout">
                    <option value="">Select...</option>
                    <option>Friend or family member</option>
                    <option>Healthcare provider</option>
                    <option>Social media</option>
                    <option>Search engine</option>
                    <option>Community event</option>
                    <option>Other</option>
                </select>
            </div>

            <div class="btn-nav">
                <button class="btn-back" onclick="goToStep(2)">← Back</button>
                <button class="btn-primary" id="submitBtn" onclick="submitForm()">Send My Message ✓</button>
            </div>
        </div>

        <!-- SUCCESS -->
        <div class="success-screen" id="successScreen">
            <div class="success-icon">✅</div>
            <h2>Message Received!</h2>
            <p>Thank you for reaching out. We'll be in touch within 48 hours at:</p>
            <p class="success-email" id="confirmEmail"></p>
            <p style="margin-top:8px;">If you don't receive a response, please email us directly at <strong>info@mindconnect.live</strong></p>

            <div class="next-steps">
                <h4>What happens next?</h4>
                <div class="next-step-item">
                    <div class="step-num">1</div>
                    <p>A team member reviews your message and matches you with the right specialist or resource.</p>
                </div>
                <div class="next-step-item">
                    <div class="step-num">2</div>
                    <p>We reach out within 48 hours via your preferred contact method to schedule a call or chat.</p>
                </div>
                <div class="next-step-item">
                    <div class="step-num">3</div>
                    <p>We create a personalized plan together — connecting you to services, providers, and ongoing support.</p>
                </div>
            </div>

            <div style="margin-top:32px;">
                <a href="index.html" style="display:inline-flex; align-items:center; gap:8px; text-decoration:none; color:var(--green); font-weight:600; font-size:15px;">← Return to Home</a>
            </div>
        </div>
    </div>
</div>

<footer>
    <div class="footer-inner">
        <div class="footer-logo">MindConnect</div>
        <div class="footer-links">
            <a href="services.html">Services</a>
            <a href="network.html">Network</a>
            <a href="mission.html">Mission</a>
            <a href="about.html">About</a>
        </div>
        <div style="font-size:13px;">© 2025 MindConnect.</div>
    </div>
</footer>

<script>
    let currentStep = 1;

    function goToStep(step) {
        if (step > currentStep && !validateStep(currentStep)) return;
        
        document.getElementById('step' + currentStep).classList.remove('active');
        currentStep = step;
        document.getElementById('step' + currentStep).classList.add('active');
        updateIndicators();
    }

    function validateStep(step) {
        let valid = true;
        if (step === 1) {
            const fn = document.getElementById('firstName').value.trim();
            const ln = document.getElementById('lastName').value.trim();
            const em = document.getElementById('email').value.trim();
            const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            showErr('err-firstName', !fn);
            showErr('err-lastName', !ln);
            showErr('err-email', !em || !emailRe.test(em));

            valid = fn && ln && em && emailRe.test(em);
        }
        if (step === 3) {
            const msg = document.getElementById('message').value.trim();
            showErr('err-message', !msg);
            valid = !!msg;
        }
        return valid;
    }

    function showErr(id, show) {
        const el = document.getElementById(id);
        if (el) el.classList.toggle('show', show);
    }

    function updateIndicators() {
        const progress = currentStep === 1 ? 33 : currentStep === 2 ? 66 : 100;
        document.getElementById('progressFill').style.width = progress + '%';

        [1, 2, 3].forEach(i => {
            const dot = document.getElementById('dot' + i);
            dot.classList.remove('done', 'active', 'pending');
            if (i < currentStep) dot.classList.add('done');
            else if (i === currentStep) dot.classList.add('active');
            else dot.classList.add('pending');
            dot.textContent = i < currentStep ? '✓' : i;
        });

        [1, 2].forEach(i => {
            const line = document.getElementById('line' + i);
            if (line) line.classList.toggle('done', currentStep > i);
        });
    }

    function toggleCheck(el) {
        el.classList.toggle('selected');
        const check = el.querySelector('.checkbox-check');
        if (el.classList.contains('selected')) {
            check.textContent = '✓';
        } else {
            check.textContent = '';
        }
    }

    function selectLang(el) {
        document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('selected'));
        el.classList.add('selected');
    }

    function submitForm() {
        if (!validateStep(3)) return;

        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.textContent = 'Sending...';

        setTimeout(() => {
            const email = document.getElementById('email').value;
            document.getElementById('confirmEmail').textContent = email;

            ['step1','step2','step3'].forEach(id => {
                document.getElementById(id).classList.remove('active');
            });

            document.getElementById('successScreen').classList.add('show');
            document.getElementById('progressFill').style.width = '100%';
        }, 1500);
    }
</script>
</body>
</html>
